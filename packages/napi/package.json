{
  "name": "@groundstate/napi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "groundstate",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cwd ../../ -p gs-napi",
    "build:debug": "napi build --platform --cwd ../../ -p gs-napi"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
